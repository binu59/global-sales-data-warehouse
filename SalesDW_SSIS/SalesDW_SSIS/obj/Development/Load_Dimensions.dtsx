                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT
    CAST(Sales_Channel AS NVARCHAR(100)) AS ChannelName,
    CAST(Order_Priority AS NVARCHAR(50)) AS OrderPriority,
    CAST(
        CASE Order_Priority
            WHEN 'H' THEN N'High'
            WHEN 'M' THEN N'Medium'
            WHEN 'L' THEN N'Low'
            WHEN 'C' THEN N'Critical'
        END AS NVARCHAR(50)
    ) AS PriorityDesc
FROM dbo.StgSalesOrders</property>
